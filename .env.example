# MagoFonte — lancia branch environment variables
# Copy to .env (never commit .env)
# On Render / Railway / Fly: set these as Secrets / Environment Variables in the dashboard

# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────

# Secret key that protects all /api/* endpoints.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# Your DGB reward address (where mined coins go)
DGB_REWARD_ADDRESS=

# DGB full-node RPC credentials
DGB_RPC_HOST=127.0.0.1
DGB_RPC_USER=dgbrpc
DGB_RPC_PASS=

# ─────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────

# Passphrase used to AES-256-GCM encrypt vault/wallets.enc.json at rest.
# If unset, wallets are stored as plaintext JSON (dev mode only).
WALLET_PASSPHRASE=

# HTTP port (default 8080; Render/Railway/Fly override this automatically)
PORT=8080

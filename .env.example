# MagoFonte — lancia branch environment variables
# Copy to .env (never commit .env)
# On Render / Railway / Fly: set these as Secrets / Environment Variables in the dashboard

# ─────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────

# API key that protects all /api/* endpoints
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# Your DGB reward address (mining rewards)
DGB_REWARD_ADDRESS=

# DGB full-node RPC credentials
DGB_RPC_HOST=127.0.0.1
DGB_RPC_USER=dgbrpc
DGB_RPC_PASS=

# Supabase connection
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Treasury — owner-controlled wallet addresses
# All revenue streams sweep to these addresses
# ─────────────────────────────────────────────────────────────────────────────

# Solana treasury wallet (LP fees, token rewards → here)
TREASURY_WALLET_ADDRESS=Fz8zVrdkXS3kDZzjkpogB9KmR9DHaJPUPGbjrqm8824J

# DGB treasury wallet (pool mining rewards → here)
# Defaults to DGB_REWARD_ADDRESS if not set
TREASURY_DGB_ADDRESS=

# LTC treasury wallet (future)
TREASURY_LTC_ADDRESS=

# ─────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────

# Solana RPC (defaults to public mainnet if not set)
SOLANA_RPC_URL=

# Helius free-tier API key (improves RPC reliability — free at helius.dev)
HELIUS_API_KEY=

# Vault passphrase for AES-256-GCM wallet encryption at rest
WALLET_PASSPHRASE=

# HTTP port (default 8080; auto-set by Render/Railway/Fly)
PORT=8080

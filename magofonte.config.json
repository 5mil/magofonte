{
  "server": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "modules": {
    "node":         { "enabled": false },
    "pool":         { "enabled": true,  "stratumPort": 3333 },
    "console":      { "enabled": true },
    "monetization": { "enabled": true },
    "vault":        { "enabled": true },
    "forge":        { "enabled": true },
    "bridge":       { "enabled": true },
    "stream":       { "enabled": true },
    "mesh":         { "enabled": true },
    "lancia":       { "enabled": true },
    "ward":         { "enabled": false },
    "sigil":        { "enabled": false }
  },
  "pool": {
    "coin":               "dgb",
    "mode":               "party",
    "algo":               "skein",
    "blockRewardAddress": "${DGB_REWARD_ADDRESS}",
    "node": {
      "host":    "${DGB_RPC_HOST:-127.0.0.1}",
      "port":    14022,
      "rpcuser": "${DGB_RPC_USER:-dgbrpc}",
      "rpcpass": "${DGB_RPC_PASS}"
    },
    "stratumPort":    3333,
    "defaultDiff":    0.01,
    "varDiff": {
      "enabled":         true,
      "minDiff":         0.001,
      "maxDiff":         1000,
      "targetTime":      15,
      "retargetTime":    60,
      "variancePercent": 30
    },
    "blockPollMs":  500,
    "payoutScheme": "PPLNS",
    "pplnsWindow":  100,
    "bonus": {
      "windowMs":       1800000,
      "operatorFeePct": 0.01,
      "dustThreshold":  1000
    }
  },
  "monetization": {
    "collectIntervalMinutes":  30,
    "sweepIntervalHours":      6,
    "sweepThresholdSol":       0.01,
    "sweepThresholdDgbSats":   100000000,
    "minClaimThreshold":       1000,
    "operatorFeePct":          0.01
  },
  "vault": {
    "backend": "mock"
  },
  "forge": {},
  "bridge": {
    "feePct": 0.005
  },
  "stream": {},
  "mesh": {
    "rewardPerTask": 0.001
  },
  "lancia": {
    "backend": "mock"
  }
}
